MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/mindgarden?retryWrites=true&w=majority
PORT=5000

# Optional but recommended: enables real LLM/GenAI parsing.
# Without this, the app automatically falls back to the local rule parser.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
